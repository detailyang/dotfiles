[Application Options]
; show staged changes
; staged = false

; file tree panel width in units (1-10, default 2 of 10)
; tree-width = 2

; number of spaces per tab character
; tab-width = 4

; disable all colors including syntax highlighting
; no-colors = false

; hide the status bar
; no-status-bar = false

; skip confirmation prompt when discarding annotations with Q
; no-confirm-discard = false

; disable mouse support (scroll wheel, click)
; no-mouse = false

; enable line wrapping in diff view
; wrap = false

; indent wrap continuation rows by N columns so they hang under the first row's content (helps when reviewing markdown lists where unindented continuation can be misread as a new bullet)
; wrap-indent = 0

; start in collapsed diff mode
; collapsed = false

; start in compact diff mode (small context around changes)
; compact = false

; number of context lines around changes when in compact mode
; compact-context = 5

; allow [ and ] to jump across file boundaries
; cross-file-hunks = false

; show line numbers in diff gutter
; line-numbers = false

; show blame gutter on startup
; blame = false

; highlight intra-line word-level changes in paired add/remove lines
; word-diff = false

; enable vim-style motion preset (counts, gg, G, zz/zt/zb, ZZ/ZQ)
; vim-motion = false

; chroma style for syntax highlighting
; chroma-style = catppuccin-macchiato

; exclude files matching prefix (may be repeated)
; exclude =

; include only files matching prefix (may be repeated)
; include =

; directory for review history auto-saves
; history-dir =

; load theme from themes directory
theme = colorblind-light

[color options]
; active pane borders and directory names
; color-accent = #D5895F

; inactive pane borders
; color-border = #585858

; file entries and context lines
; color-normal = #d0d0d0

; line numbers and status bar
; color-muted = #585858

; selected file text color
; color-selected-fg = #ffffaf

; selected file background color
; color-selected-bg = #D5895F

; annotation text and markers
; color-annotation = #ffd700

; diff cursor indicator color
; color-cursor-fg = #bbbb44

; diff cursor indicator background
; color-cursor-bg =

; added line text color
; color-add-fg = #87d787

; added line background color
; color-add-bg = #123800

; removed line text color
; color-remove-fg = #ff8787

; removed line background color
; color-remove-bg = #4D1100

; intra-line word-diff add background (auto-derived if empty)
; color-word-add-bg =

; intra-line word-diff remove background (auto-derived if empty)
; color-word-remove-bg =

; modified line text color (collapsed mode)
; color-modify-fg = #f5c542

; modified line background color (collapsed mode)
; color-modify-bg = #3D2E00

; file tree pane background
; color-tree-bg =

; diff pane background
; color-diff-bg =

; status bar foreground
; color-status-fg = #202020

; status bar background
; color-status-bg = #C5794F

; search match foreground
; color-search-fg = #1a1a1a

; search match background
; color-search-bg = #4a4a00

