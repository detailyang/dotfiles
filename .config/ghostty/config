shell-integration = fish
command = /usr/local/bin/fish -l -c "if tmux has-session -t main 2>/dev/null; and tmux list-sessions -f '#{==:#{session_name},main}' 2>/dev/null | grep -q '(attached)'; exec fish; else if tmux has-session -t main 2>/dev/null; tmux attach -t main; else; tmux new-session -s main; end"
font-family = "JetBrains Mono"
font-size = 14
macos-titlebar-style = tabs
background-opacity = 0.9
theme = Alabaster
term = xterm
keybind = performable:ctrl+v=paste_from_clipboard
keybind = performable:ctrl+c=copy_to_clipboard
clipboard-paste-bracketed-safe = false
unfocused-split-opacity = 0.55
shell-integration-features = ssh-terminfo,ssh-env
